{
  "name": "bmi-gestion-boutiques",
  "private": true,
  "version": "2.95.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "dist": "vite build && electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dexie": "^4.0.8",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "tg.bmi.gestionboutiques",
    "productName": "BMI-Gestions Boutiques",
    "files": [
      "dist/**",
      "electron/**",
      "public/pwa-512.png"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BMI Gestion Boutiques"
    }
  }
}
