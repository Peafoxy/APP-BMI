# Copiez ce fichier en ".env" et remplissez avec vos valeurs Supabase
# (Projet Supabase -> Settings -> API)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_ici

# Facultatif, uniquement pour la version Windows (Electron) — l'adresse
# complète de votre site Vercel, pour que l'app sécurise ses connexions.
# Laissez vide/absent pour la version web (PWA), elle n'en a pas besoin.
# Exemple : VITE_SYNC_AUTH_URL=https://votre-site.vercel.app
# (l'adresse de base suffit ; l'ancienne forme avec /api/sync-auth reste acceptée)
VITE_SYNC_AUTH_URL=

# IMPORTANT : la clé "service_role" de Supabase NE VA JAMAIS dans ce
# fichier .env ni dans aucun fichier envoyé au navigateur. Elle se
# configure UNIQUEMENT dans Vercel -> Settings -> Environment Variables,
# sous le nom SUPABASE_SERVICE_ROLE_KEY (sans le préfixe VITE_).
